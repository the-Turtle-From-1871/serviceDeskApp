generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id                String    @id @default(cuid())
  rank              String?
  name              String
  email             String    @unique
  unit              String?
  contactNumber     String?
  passwordHash      String
  signatureImage    String?
  role              Role      @default(USER)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  passwordChangedAt DateTime?
  // Set when the account transitions to inactive (cleared on reactivation). A
  // dedicated signal — unlike updatedAt, which any edit bumps — so the account
  // purge worker can hard-delete accounts deactivated for 3+ months. Existing
  // already-deactivated users have null here and are treated as not-yet-eligible.
  deactivatedAt     DateTime?

  createdItems     Item[]               @relation("CreatedItems")
  createdTransfers Transfer[]           @relation("CreatedTransfers")
  importBatches    ImportBatch[]        @relation("ImportBatches")
  returnsProcessed ReturnTransaction[]  @relation("ReturnsProcessed")
  passwordResets   PasswordResetToken[] @relation("PasswordResets")
}

// Self-service password reset. Only the SHA-256 hash of the emailed token is
// stored, so a DB leak can't be used to reset. Single-use (usedAt) + expiry.
model PasswordResetToken {
  id        String    @id @default(cuid())
  user      User      @relation("PasswordResets", fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

enum ItemStatus {
  ACTIVE
  RETIRED
}

model Item {
  id            String         @id @default(cuid())
  make          String
  model         String
  serialNumber  String
  homeUnit      String?
  deviceName    String?
  notes         String?
  status        ItemStatus     @default(ACTIVE)
  createdBy     User           @relation("CreatedItems", fields: [createdById], references: [id])
  createdById   String
  transferItems TransferItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Unit {
  id           String   @id @default(cuid())
  abbreviation String   @unique
  fullName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum TransferStatus {
  OPEN
  CLOSED
}

enum ReturnKind {
  PARTIAL
  FULL
}

model Transfer {
  id            String         @id @default(cuid())
  receiptNumber String         @unique
  itemSummary   String
  lines         TransferLine[]

  senderIsDcsim Boolean @default(false)
  senderName    String
  senderRank    String?
  senderUnit    String?
  senderContact String?
  senderEmail   String?

  receiverIsDcsim Boolean @default(false)
  receiverName    String
  receiverRank    String?
  receiverUnit    String?
  receiverContact String?
  receiverEmail   String?

  receiverSignature String

  createdByUser   User?   @relation("CreatedTransfers", fields: [createdByUserId], references: [id])
  createdByUserId String?

  status    TransferStatus @default(OPEN)
  createdAt DateTime       @default(now())

  // Lifecycle: set when the receipt (ticket) transitions to CLOSED. Once set the
  // record is immutable. `purgeAfter` = closedAt + 90 days; the purge worker
  // permanently deletes records whose purgeAfter has passed.
  closedAt   DateTime?
  purgeAfter DateTime?

  returns ReturnTransaction[] @relation("TransferReturns")

  // [Ingest & Routing Queue] Back-reference for the service queue. Every ingested
  // receipt is routed into the primary service queue (see ServiceQueueItem).
  queueItems ServiceQueueItem[] @relation("TransferQueueItems")

  @@index([purgeAfter])
}

model TransferLine {
  id          String         @id @default(cuid())
  transfer    Transfer       @relation(fields: [transferId], references: [id], onDelete: Cascade)
  transferId  String
  lineNo      Int
  make        String
  model       String
  unitOfIssue String         @default("EA")
  qtyAuth     Int
  qtyIssued   Int
  items       TransferItem[]

  @@index([transferId])
}

model TransferItem {
  id             String       @id @default(cuid())
  line           TransferLine @relation(fields: [transferLineId], references: [id], onDelete: Cascade)
  transferLineId String
  item           Item         @relation(fields: [itemId], references: [id])
  itemId         String
  serialNumber   String
  returnedAt     DateTime?

  @@index([itemId])
  @@index([transferLineId])
}

model ImportBatch {
  id           String   @id @default(cuid())
  createdBy    User     @relation("ImportBatches", fields: [createdById], references: [id])
  createdById  String
  filename     String
  addedCount   Int
  skippedCount Int
  skipped      Json
  createdAt    DateTime @default(now())

  @@index([createdById])
}

model ReturnTransaction {
  id                   String     @id @default(cuid())
  transfer             Transfer   @relation("TransferReturns", fields: [transferId], references: [id], onDelete: Cascade)
  transferId           String
  receiptNumber        String
  kind                 ReturnKind
  processedByUser      User?      @relation("ReturnsProcessed", fields: [processedByUserId], references: [id])
  processedByUserId    String?
  processedByName      String
  processedByEmail     String
  processedBySignature String?
  returned             Json
  returnedCount        Int
  remainingCount       Int
  createdAt            DateTime   @default(now())

  @@index([transferId])
}

// [Ingest & Routing Queue] Lifecycle states for a service-queue entry.
enum ServiceQueueStatus {
  // Primary/service state. Every ingested receipt lands here for processing and
  // is shown on the Admin Queue as requiring active service/intervention.
  PENDING
  // "Ready to issue when needed" — an admin removed the item from the Admin
  // Queue. The record is retained (never deleted) and drops off the active view.
  READY_TO_ISSUE
}

// [Ingest & Routing Queue] Operational queue entry for a receipt (Transfer).
// The ingestion pipeline creates one PENDING entry per incoming receipt so it is
// processed in the service queue before reaching admin views.
model ServiceQueueItem {
  id         String             @id @default(cuid())
  transfer   Transfer           @relation("TransferQueueItems", fields: [transferId], references: [id], onDelete: Cascade)
  transferId String
  status     ServiceQueueStatus @default(PENDING)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([transferId])
  @@index([status])
}
