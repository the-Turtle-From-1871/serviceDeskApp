# ---- Local development ----
# Points at the Docker Postgres from docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5435/handreceipt?schema=public"

# Auth.js secret. Generate one with: npx auth secret
AUTH_SECRET="generate-with: npx auth secret"

# Absolute base URL of the app. Used to build scannable QR code links.
APP_URL="http://localhost:3000"

# Transactional email (optional in dev — without these, receipt links are
# logged to the console via a stub sender instead of actually being sent).
RESEND_API_KEY=
EMAIL_FROM="Hand Receipt <receipts@turtolabs.com>"

# ---- Production (Vercel + Supabase) ----
# DATABASE_URL  -> Supabase TRANSACTION pooler (port 6543), used by the app at
#                  runtime. Must end with ?pgbouncer=true
# DIRECT_URL    -> Supabase SESSION pooler / direct connection (port 5432), used
#                  only by `prisma migrate deploy`.
# AUTH_SECRET   -> a fresh secret (do NOT reuse the dev one): npx auth secret
# APP_URL       -> your deployed URL, e.g. https://service-desk-app.vercel.app
#
# Optionally override the seeded admin (defaults: admin@example.com / ChangeMe123!):
# SEED_ADMIN_EMAIL="admin@yourorg.com"
# SEED_ADMIN_PASSWORD="a-strong-password"
